{
  "name": "tailwindcss-bun-plugin",
  "version": "4.2.1",
  "description": "Tailwind CSS v4 plugin for Bun.build.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/iivankin/tailwindcss-bun-plugin.git"
  },
  "keywords": [
    "bun",
    "bun-plugin",
    "tailwindcss",
    "tailwind",
    "css"
  ],
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "bun ./scripts/prepare.ts",
    "check": "ultracite check",
    "typecheck": "tsc",
    "test": "bun test",
    "fix": "ultracite fix",
    "stage:binary-package": "bun ./scripts/stage-binary-package.ts",
    "stage:root-package": "bun ./scripts/stage-root-package.ts"
  },
  "dependencies": {
    "@tailwindcss/node": "4.2.1",
    "tailwindcss": "4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@napi-rs/cli": "3.4.1",
    "@types/bun": "1.3.10",
    "@types/node": "25.5.0",
    "lefthook": "2.1.4",
    "typescript": "5.9.3",
    "ultracite": "7.3.1"
  }
}
